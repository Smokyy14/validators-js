{
  "name": "@smokyy14/validators-js",
  "version": "0.1.3",
  "description": "Unified validators library (email, URL, IP, credit cards, UUID, hashes and more), inspired by Python's validators package.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "validators",
    "validation",
    "email",
    "url",
    "ip",
    "uuid",
    "credit-card",
    "hash",
    "typescript"
  ],
  "author": "Astrax",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.14.0",
    "eslint": "^9.9.0",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=16"
  }
}
